# =============================================================================
# DevDuel Mobile – Appium E2E Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running tests.

# ── Android device / emulator ────────────────────────────────────────────────
DEVICE_NAME=emulator-5554
PLATFORM_VERSION=14.0
APP_PACKAGE=com.example.devduel_mobile
APP_ACTIVITY=.MainActivity
# Path to the compiled APK (leave empty if app is already installed)
APP_PATH=

# ── Appium server ────────────────────────────────────────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── Test credentials (must already exist in your backend) ───────────────────
TEST_EMAIL=testuser@devduel.com
TEST_PASSWORD=Test@1234
TEST_USERNAME=TestDev

# ── Backend API base URL ─────────────────────────────────────────────────────
API_BASE_URL=http://10.0.2.2:8000

# ── Timeouts (seconds) ───────────────────────────────────────────────────────
IMPLICIT_WAIT=10
EXPLICIT_WAIT=20
